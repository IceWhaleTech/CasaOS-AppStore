# Copy this file to ".env" for local builds.

# Optional: Docker Hub credentials used to reduce anonymous registry rate limits.
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# Optional: Base URL used when generating absolute asset links in dist outputs.
# Example:
# BASE_URL=https://cdn.jsdelivr.net/gh/IceWhaleTech/CasaOS-AppStore@gh-pages
BASE_URL=

# Optional: Override default build paths.
# SOURCE_DIR=/absolute/path/to/CasaOS-AppStore
# OUTPUT_DIR=/absolute/path/to/CasaOS-AppStore/dist
# CACHE_DIR=/absolute/path/to/CasaOS-AppStore/.cache/build_appstore
# IMAGE_SIZE_CACHE_FILE=/absolute/path/to/image-size-cache.json
# IMAGE_DIGEST_CACHE_FILE=/absolute/path/to/image-digest-cache.json

# Optional: Use a different env file with:
# ENV_FILE=/absolute/path/to/your.env ./scripts/build_dist.sh
